{
  "name": "@bandz/functions",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "postbuild": "mkdir -p dist/assets && cp src/assets/*.woff dist/assets/",
    "build:watch": "tsc --watch --project tsconfig.json",
    "dev": "pnpm build:watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@bandz/shared": "workspace:*",
    "@google-cloud/functions-framework": "^5.0.2",
    "@resvg/resvg-js": "^2.6.2",
    "chance": "^1.1.13",
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^7.0.0",
    "jose": "^6.0.0",
    "satori": "^0.12.1",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@resvg/resvg-js-darwin-x64": "^2.6.2",
    "@types/chance": "^1.1.7",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}