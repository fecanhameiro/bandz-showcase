---
import type { Locale } from "../i18n/translations";
import { t } from "../i18n/translations";
import PhoneMockup from "./PhoneMockup.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);

const features = [
  {
    ...i.features.discover,
    screenshot: "/feature-discover.png",
    alt: "bandz app — event discovery",
    accent: "indigo" as const,
  },
  {
    ...i.features.notifications,
    screenshot: "/feature-profile.png",
    alt: "bandz app — your music profile",
    accent: "pink" as const,
  },
  {
    ...i.features.places,
    screenshot: "/feature-search.png",
    alt: "bandz app — search venues and genres",
    accent: "teal" as const,
  },
];
---

<section id="features" class="relative py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-20 reveal">
      <h2 class="section-heading font-bold tracking-tight mb-4">
        {i.features.title}
      </h2>
      <div class="w-20 h-1 mx-auto rounded-full" style="background: linear-gradient(to right, var(--color-brand-indigo), var(--color-brand-secondary))"></div>
    </div>

    <div class="space-y-24 lg:space-y-32">
      {
        features.map((feature, idx) => {
          const isReversed = idx % 2 === 1;
          const accentClass = `feature-accent-${feature.accent}`;

          return (
            <div
              class="reveal feature-row grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center"
              style={`animation-delay: ${idx * 0.15}s`}
            >
              {/* Text side */}
              <div class={`text-center lg:text-left reveal-stagger ${isReversed ? "lg:order-2" : ""}`}>
                {/* Icon */}
                <div class={`inline-flex items-center justify-center w-14 h-14 rounded-2xl mb-6 ${accentClass}`}>
                  {feature.accent === "indigo" && (
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z" />
                    </svg>
                  )}
                  {feature.accent === "pink" && (
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9" />
                      <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0" />
                    </svg>
                  )}
                  {feature.accent === "teal" && (
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                      <circle cx="12" cy="10" r="3" />
                    </svg>
                  )}
                </div>

                <h3 class="text-2xl sm:text-3xl font-bold tracking-tight mb-4">{feature.title}</h3>
                <p class="text-text-secondary leading-relaxed text-lg max-w-md mx-auto lg:mx-0">
                  {feature.description}
                </p>
              </div>

              {/* Phone side */}
              <div class={`flex justify-center ${isReversed ? "lg:order-1 lg:justify-start" : "lg:justify-end"}`}>
                <div class={`feature-phone-wrapper ${accentClass}-glow`}>
                  <PhoneMockup
                    src={feature.screenshot}
                    alt={feature.alt}
                  />
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  /* Feature accent icon backgrounds */
  .feature-accent-indigo {
    background: var(--color-glow-primary);
    color: var(--color-brand-indigo-light);
  }

  .feature-accent-pink {
    background: var(--color-glow-secondary);
    color: var(--color-brand-secondary);
  }

  .feature-accent-teal {
    background: var(--color-glow-teal);
    color: var(--color-brand-teal);
  }

  /* Glow behind phone mockups */
  .feature-phone-wrapper {
    position: relative;
  }

  .feature-phone-wrapper::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: clamp(200px, 50vw, 300px);
    height: clamp(200px, 50vw, 300px);
    border-radius: 50%;
    opacity: 0.15;
    filter: blur(80px);
    z-index: -1;
    transition: opacity 0.4s ease;
  }

  .feature-row:hover .feature-phone-wrapper::before {
    opacity: 0.25;
  }

  .feature-accent-indigo-glow::before {
    background: var(--color-brand-indigo);
  }

  .feature-accent-pink-glow::before {
    background: var(--color-brand-secondary);
  }

  .feature-accent-teal-glow::before {
    background: var(--color-brand-teal);
  }
</style>
